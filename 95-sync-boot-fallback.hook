[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Operation = Remove
Target = usr/lib/modules/*/vmlinuz
Target = usr/lib/initcpio/*
Target = boot/*

[Action]
Description = Syncing /boot to /boot_fallback...
When = PostTransaction
Exec = /usr/bin/sync-boot-fallback
Depends = rsync
Depends = util-linux